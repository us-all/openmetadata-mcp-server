{
  "name": "@us-all/openmetadata-mcp",
  "version": "1.10.1",
  "description": "OpenMetadata MCP server - metadata management, lineage, search, data quality, and more",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openmetadata-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretoken-stats": "pnpm run build",
    "token-stats": "node scripts/measure-tokens.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@us-all/mcp-toolkit": "^0.2.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.14"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/us-all/openmetadata-mcp-server"
  },
  "license": "MIT"
}
